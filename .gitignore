# ──────────────────────────────────────────────────────────────────────────────
#  WorkPilot AI — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Database ──────────────────────────────────────────────────────────────────
backend/data/
*.db
*.sqlite
*.sqlite3

# ── Vector DB ─────────────────────────────────────────────────────────────────
backend/chroma_store/

# ── Uploaded Files ────────────────────────────────────────────────────────────
backend/uploads/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Next.js (Phase 5) ─────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.env.local
frontend/.env*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary ─────────────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
