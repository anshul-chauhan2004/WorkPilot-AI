# ──────────────────────────────────────────────────────────────────
#  WorkPilot AI — Environment Variables Template
#
#  Setup:
#    cp backend/.env.example backend/.env
#    Then fill in your actual values below.
#
#  ⚠️  Never commit backend/.env — it is gitignored.
# ──────────────────────────────────────────────────────────────────

# ── Gemini API ────────────────────────────────────────────────────
# Required. Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name — change without touching code
# Recommended options:
#   gemini-2.0-flash          (fast, cost-effective — default)
#   gemini-2.0-flash-lite     (lightest, lowest cost)
#   gemini-1.5-pro            (most capable)
GEMINI_MODEL=gemini-2.0-flash

# ── Storage Paths ─────────────────────────────────────────────────
# All paths are relative to the backend/ directory.
SQLITE_DB_PATH=data/workpilot.db
CHROMA_PERSIST_PATH=chroma_store
UPLOADS_PATH=uploads

# ── Server ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
